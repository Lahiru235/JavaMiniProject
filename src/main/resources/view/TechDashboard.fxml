<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.TechDashboardController"
            style="-fx-font-size: 13px;">

    <!-- TOP BAR -->
    <top>
        <HBox style="-fx-background-color:#2c3e50; -fx-padding:10;">
            <Label fx:id="welcomeLabel" style="-fx-text-fill:white; -fx-font-size:14px; -fx-font-weight:bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color:#e74c3c; -fx-text-fill:white;"/>
        </HBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" style="-fx-padding:8;">

            <!-- ── TAB 1: Record Attendance ─────────────────── -->
            <Tab text="Record Attendance">
                <VBox spacing="10" style="-fx-padding:15;">
                    <Label text="Record Attendance" style="-fx-font-size:16px; -fx-font-weight:bold;"/>
                    <GridPane hgap="10" vgap="8">
                        <Label text="Student:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <ComboBox fx:id="studentCombo" prefWidth="160" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <Label text="Course:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                        <ComboBox fx:id="courseCombo" prefWidth="130" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                        <Label text="Type:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <ComboBox fx:id="typeCombo" prefWidth="130" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        <Label text="Session #:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                        <ComboBox fx:id="sessionCombo" prefWidth="80" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

                        <Label text="Date:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <DatePicker fx:id="sessionDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                        <Label text="Present:" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                        <CheckBox fx:id="presentCheck" selected="true" GridPane.columnIndex="3" GridPane.rowIndex="2"/>
                    </GridPane>
                    <HBox spacing="10">
                        <Button text="Save Attendance" onAction="#handleSaveAttendance"
                                style="-fx-background-color:#27ae60; -fx-text-fill:white; -fx-padding:6 16;"/>
                    </HBox>
                    <Label fx:id="attStatusLabel"/>

                    <Separator/>
                    <Label text="View Summary" style="-fx-font-weight:bold;"/>
                    <HBox spacing="10">
                        <Button text="View Batch Summary"      onAction="#handleViewBatchSummary"
                                style="-fx-background-color:#2980b9; -fx-text-fill:white; -fx-padding:6 12;"/>
                        <Button text="View Individual Summary" onAction="#handleViewIndividualSummary"
                                style="-fx-background-color:#8e44ad; -fx-text-fill:white; -fx-padding:6 12;"/>
                    </HBox>

                    <TableView fx:id="summaryTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colStudent" text="Student"    prefWidth="90"/>
                            <TableColumn fx:id="colCourse"  text="Course"     prefWidth="90"/>
                            <TableColumn fx:id="colPresent" text="Present"    prefWidth="70"/>
                            <TableColumn fx:id="colPct"     text="Raw %"      prefWidth="70"/>
                            <TableColumn fx:id="colEffPct"  text="Eff. %"     prefWidth="70"/>
                            <TableColumn fx:id="colEligible" text="Eligible?" prefWidth="90"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- ── TAB 2: Medical Records ───────────────────── -->
            <Tab text="Medical Records">
                <VBox spacing="10" style="-fx-padding:15;">
                    <Label text="Medical Records" style="-fx-font-size:16px; -fx-font-weight:bold;"/>
                    <GridPane hgap="10" vgap="8">
                        <Label text="Student ID:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="medStudentField" promptText="e.g. TG1701"
                                   prefWidth="140" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <Label text="From:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                        <DatePicker fx:id="medFromPicker" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                        <Label text="To:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <DatePicker fx:id="medToPicker" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        <Label text="Reason:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                        <TextField fx:id="medReasonField" prefWidth="200" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                    </GridPane>
                    <HBox spacing="10">
                        <Button text="Save Medical"      onAction="#handleSaveMedical"
                                style="-fx-background-color:#27ae60; -fx-text-fill:white; -fx-padding:6 16;"/>
                        <Button text="Approve Selected"  onAction="#handleApproveMedical"
                                style="-fx-background-color:#f39c12; -fx-text-fill:white; -fx-padding:6 16;"/>
                        <Button text="Refresh List"      onAction="#handleViewMedicals"
                                style="-fx-background-color:#2980b9; -fx-text-fill:white; -fx-padding:6 12;"/>
                    </HBox>
                    <Label fx:id="medStatusLabel"/>

                    <TableView fx:id="medTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colMedStudent" text="Student"  prefWidth="90"/>
                            <TableColumn fx:id="colMedFrom"    text="From"     prefWidth="100"/>
                            <TableColumn fx:id="colMedTo"      text="To"       prefWidth="100"/>
                            <TableColumn fx:id="colMedReason"  text="Reason"   prefWidth="200"/>
                            <TableColumn fx:id="colMedStatus"  text="Status"   prefWidth="90"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <Tab text="Department Timetable">
                <VBox spacing="10" style="-fx-padding:15;">
                    <Label text="Department Timetable" style="-fx-font-size:16px; -fx-font-weight:bold;"/>
                    <HBox spacing="10">
                        <Button text="Refresh Timetable" onAction="#handleViewDeptTimetable"
                                style="-fx-background-color:#2980b9; -fx-text-fill:white; -fx-padding:6 16;"/>
                    </HBox>
                    <Label fx:id="timetableStatusLabel"/>

                    <TableView fx:id="timetableTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colTDay" text="Day" prefWidth="110"/>
                            <TableColumn fx:id="colTStart" text="Start" prefWidth="90"/>
                            <TableColumn fx:id="colTEnd" text="End" prefWidth="90"/>
                            <TableColumn fx:id="colTCourse" text="Course" prefWidth="100"/>
                            <TableColumn fx:id="colTVenue" text="Venue" prefWidth="160"/>
                            <TableColumn fx:id="colTNote" text="Note" prefWidth="230"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <Tab text="Notices">
                <BorderPane>
                    <center>
                        <fx:include source="NoticeBoard.fxml"/>
                    </center>
                </BorderPane>
            </Tab>

            <Tab text="My Profile">
                <VBox spacing="10" style="-fx-padding:15;">
                    <Label text="Update Profile" style="-fx-font-size:16px; -fx-font-weight:bold;"/>
                    <Label text="Username and password cannot be changed here." style="-fx-text-fill:#666;"/>

                    <GridPane hgap="10" vgap="8">
                        <Label text="Full Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="profNameField" prefWidth="260" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="profEmailField" prefWidth="260" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="Phone:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <TextField fx:id="profPhoneField" prefWidth="260" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Label text="Department:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <TextField fx:id="profDeptField" prefWidth="260" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                    </GridPane>

                    <HBox spacing="10">
                        <Button text="Update Profile" onAction="#handleUpdateProfile"
                                style="-fx-background-color:#27ae60; -fx-text-fill:white; -fx-padding:6 16;"/>
                    </HBox>

                    <Label fx:id="profileStatusLabel"/>
                </VBox>
            </Tab>

        </TabPane>
    </center>
</BorderPane>
