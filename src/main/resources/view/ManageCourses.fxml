<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.ManageCoursesController"
      spacing="10">

    <padding><Insets top="10" right="14" bottom="10" left="14"/></padding>

    <Label text="Manage Courses"
           style="-fx-font-size: 17px; -fx-font-weight: bold;"/>

    <!-- TABLE -->
    <TableView fx:id="courseTable" prefHeight="280" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colCode"     text="Code"     prefWidth="120"/>
            <TableColumn fx:id="colName"     text="Course Name" prefWidth="260"/>
            <TableColumn fx:id="colCredits"  text="Credits"  prefWidth="80"/>
            <TableColumn fx:id="colLecturer" text="Lecturer" prefWidth="200"/>
        </columns>
        <placeholder><Label text="No courses found."/></placeholder>
    </TableView>

    <Separator/>
    <Label text="Course Details" style="-fx-font-weight: bold;"/>

    <!-- FORM -->
    <GridPane hgap="12" vgap="8">

        <Label text="Course Code:"
               GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="codeField" prefWidth="200"
                   promptText="e.g. ICT2132"
                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Course Name:"
               GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="nameField" prefWidth="300"
                   promptText="e.g. Object Oriented Programming"
                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Credits:"
               GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="creditsField" prefWidth="80"
                   promptText="e.g. 3"
                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="Lecturer:"
               GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <ComboBox fx:id="lecturerCombo" prefWidth="260"
                  GridPane.columnIndex="1" GridPane.rowIndex="3"/>

    </GridPane>

    <Label fx:id="statusLabel" style="-fx-font-size: 12px;"/>

    <!-- BUTTONS -->
    <HBox spacing="10">
        <Button text="+ New"  onAction="#handleNew"
                style="-fx-background-color: #1565C0; -fx-text-fill: white;
                       -fx-pref-width: 90px; -fx-cursor: hand;"/>
        <Button text="Save"   onAction="#handleSave"
                style="-fx-background-color: #2E7D32; -fx-text-fill: white;
                       -fx-pref-width: 90px; -fx-cursor: hand;"/>
        <Button text="Delete" onAction="#handleDelete"
                style="-fx-background-color: #C62828; -fx-text-fill: white;
                       -fx-pref-width: 90px; -fx-cursor: hand;"/>
    </HBox>

</VBox>
