<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.AdminDashboardController"
            prefWidth="1100" prefHeight="700">

    <!-- TOP BAR -->
    <top>
        <HBox style="-fx-background-color: #1A237E; -fx-padding: 12 20;"
              alignment="CENTER_LEFT" spacing="16">

            <Label text="Faculty of Technology — Management System"
                   style="-fx-text-fill: white; -fx-font-size: 15px;
                          -fx-font-weight: bold;"/>

            <Label fx:id="welcomeLabel"
                   style="-fx-text-fill: #9FA8DA; -fx-font-size: 13px;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: #EF5350;
                           -fx-text-fill: white; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox prefWidth="200" spacing="2"
              style="-fx-background-color: #283593; -fx-padding: 20 0;">

            <Label text="ADMIN MENU"
                   style="-fx-text-fill: #9FA8DA; -fx-font-size: 11px;
                          -fx-padding: 0 20 8 20;"/>

            <Button text="  Manage Users"
                    onAction="#showManageUsers"
                    maxWidth="Infinity"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: white; -fx-alignment: CENTER_LEFT;
                           -fx-padding: 11 20; -fx-cursor: hand;"/>

            <Button text="  Manage Courses"
                    onAction="#showManageCourses"
                    maxWidth="Infinity"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: white; -fx-alignment: CENTER_LEFT;
                           -fx-padding: 11 20; -fx-cursor: hand;"/>

           <Button text="  Manage Timetables"
                  onAction="#showManageTimetables"
                  maxWidth="Infinity"
                  style="-fx-background-color: transparent;
                        -fx-text-fill: white; -fx-alignment: CENTER_LEFT;
                        -fx-padding: 11 20; -fx-cursor: hand;"/>

            <Button text="  Notice Board"
                    onAction="#showNoticeBoard"
                    maxWidth="Infinity"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: white; -fx-alignment: CENTER_LEFT;
                           -fx-padding: 11 20; -fx-cursor: hand;"/>
        </VBox>
    </left>

    <!-- MAIN CONTENT AREA -->
    <center>
        <StackPane fx:id="contentArea"
                   style="-fx-background-color: #FAFAFA; -fx-padding: 20;"/>
    </center>

</BorderPane>
